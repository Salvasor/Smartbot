  "guardian": {
    "_comment": "Reglas absolutas. El score NO las mueve.",
    "usdt_min_pct": 15.0,
    "pnl_dia_min_pct": -5.0,
    "leverage_block": "high",
    "rules": [
      {
        "id": "G1",
        "desc": "Capital mínimo",
        "condition": "usdt_reserve_pct < 15",
        "effect": "BLOCK_BUY"
      },
      {
        "id": "G2",
        "desc": "BTC disponible",
        "condition": "btc_disponible == 0",
        "effect": "BLOCK_SELL"
      },
      {
        "id": "G3",
        "desc": "Riesgo sistémico",
        "condition": "leverage_risk == high",
        "effect": "BLOCK_BUY"
      },
      {
        "id": "G4",
        "desc": "Stop del día",
        "condition": "pnl_dia_pct <= -5.0",
        "effect": "BLOCK_ALL"
      }
    ]
  },
