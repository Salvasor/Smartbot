  "hard_take_profit": {
    "enabled": true,
    "min_pnl_pct": 1.0,
    "min_pos_1m": 0.75,
    "min_score_tp": 10,
    "pullback_from_max_pct": 0.2,
    "sell_pct": 1.0,
    "allowed_regimes": [
      "LATERAL_DEFINIDO",
      "LATERAL_DEBIL",
      "CORRECCION",
      "REBOTE_BAJISTA",
      "BAJISTA_MODERADO",
      "BAJISTA_DUDOSO"
    ]
