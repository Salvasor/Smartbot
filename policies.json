  "symbol": "BTC/USDT",
  "trailing_profit": {
    "_comment": "Trailing stop sobre ganancia. Si el PnL del lote retrocede desde su máximo histórico más de 'retroceso_pct', se vende. Solo activa cuando pnl supera 'min_pnl_activacion_pct'.",
    "enabled": true,
    "min_pnl_activacion_pct": 0.5,
    "_comment_min": "El trailing solo se activa cuando el lote llega a este PnL mínimo (0.5%). Por debajo de esto no se trackea máximo — evita vender dips normales de entrada.",
    "retroceso_pct": 0.35,
    "_comment_retroceso": "Si el PnL baja más de este % desde el máximo visto, vende. Ej: max=1.2%, retroceso=0.35% → vende si PnL cae a 0.85% o menos.",
    "sell_pct": 1.0,
    "_comment_sell": "Siempre vende el 100% del lote. El trailing es una salida de emergencia de ganancia."
  },
  "score_ema": {
    "_comment": "EMA del score_compra para capturar señales sostenidas que nunca llegan al umbral exacto en un solo snapshot.",
    "enabled": true,
    "alpha": 0.35,
    "_comment_alpha": "0.35 ≈ 5-6 loops de memoria. Más bajo = más lento pero más suave. Más alto = responde más rápido pero más ruidoso.",
    "delta_umbral": 6,
    "_comment_delta": "El EMA puede disparar compra si score_ema >= umbral - delta_umbral. Ej: umbral=70, delta=6 → EMA dispara con 64. Exige que además score_actual >= umbral - 12.",
    "delta_score_actual": 12,
    "_comment_delta2": "El score del snapshot actual también debe estar suficientemente alto (umbral - 12) para evitar que el EMA arrastre una compra cuando la señal ya se enfrió."
  }
